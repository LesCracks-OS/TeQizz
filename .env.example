# =============================================================================
# TeQizz — Variables d'environnement production
# =============================================================================
# Copier ce fichier en .env sur le serveur : /root/teqizz/.env
# NE PAS commiter le fichier .env
# =============================================================================

# ── Base de données ────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://teqizz-postgres:5432/teqizz
DB_NAME=teqizz
DB_USERNAME=teqizz
DB_PASSWORD=CHANGE_ME_strong_password

# ── Spring JPA ────────────────────────────────────────────────────────────────
# "update" pour le premier déploiement (crée les tables automatiquement)
# Changer en "validate" après le premier déploiement réussi
SPRING_DDL_AUTO=update

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_minimum_256_bits_random_string_here_xxxxxxxxxxxxxxxxxxxxx

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://teqizz.lescracks.com

# ── OAuth2 ────────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=CHANGE_ME
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# ── MinIO (object storage — avatars) ─────────────────────────────────────────
# MINIO_URL    : URL interne Docker (ne pas modifier)
# MINIO_PUBLIC_URL : URL publique via Traefik (remplacer par votre domaine)
MINIO_URL=http://minio:9000
MINIO_PUBLIC_URL=https://storage.teqizz.lescracks.com
MINIO_ACCESS_KEY=CHANGE_ME_minio_access_key
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_key
MINIO_BUCKET=teqizz-avatars

# ── Serveur ───────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
